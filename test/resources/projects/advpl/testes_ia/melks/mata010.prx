/*/{Protheus.doc} mata010OPC
VisualizańŃo dos opcionais do produto
@author Lucas Konrad Franńa
@since 26/09/2016
@version 1.0
/*/
// ---------------------------------------------------------
Function mata010OPC()
	If Empty(SB1->B1_OPC) .And. Empty(SB1->B1_MOPC)
		Help( ,, 'Help',, STR0114 , 1, 0 ) //"Produto nŃo possui opcionais."
	Else
		VisualOpc(SB1->B1_COD,SB1->B1_MOPC,SB1->B1_OPC,2)
	EndIf
Return .T.


