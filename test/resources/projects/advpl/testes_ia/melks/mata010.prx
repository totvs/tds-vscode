▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
FUNCTION A010Preco()

	LOCAL cPer := Substr(ReadVar(),10,1), cVar
	If "B1_"$ReadVar()
		cVar := "B1_DTREFP" + cPer
	Elseif "B5_"$ReadVar()
		cVar := "B5_DTREFP" + cPer
	Endif

	If &(ReadVar()) > 0
		M->&cVar := dDataBase
	Endif
Return(.T.)


/*
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
