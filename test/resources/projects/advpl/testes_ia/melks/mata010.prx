▒▒├──────────┼────────────────────────────────────────────────────────────┤▒▒
▒▒│ Uso      │ A010INCLUI e A010ALTERA                                    │▒▒
▒▒└──────────┴────────────────────────────────────────────────────────────┘▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
Function A010AtuDesc()

Local cQuery   as character
Local cTamanho as character
Local cSubstr  as character
Local nTam     as numeric
 
nTam := TamSX3("A5_NOMPROD")[1]
cTamanho := cValToChar(nTam) 

If !Empty(SB1->B1_COD)
	PERGUNTE("MTA010",.F.) // para restaurar as perguntas da rotina
	If mv_par01 == 1
		cSubstr := If(TCGetDB() $ "ORACLE/POSTGRES/DB2/400/INFORMIX","SUBSTR","SUBSTRING")
		
		cQuery := "UPDATE "+RetSqlName('SA5')+" SET A5_NOMPROD = "
		cQuery += " (SELECT "+cSubstr+"(B1_DESC,1,"+cTamanho+") FROM "+RetSqlName('SB1')+" WHERE B1_FILIAL = '"+FwxFilial('SB1')+"' AND "
		cQuery += " B1_COD = A5_PRODUTO AND D_E_L_E_T_ = ' ') "
		cQuery += " WHERE A5_FILIAL = '"+FwxFilial('SA5')+"' AND A5_PRODUTO = '"+SB1->B1_COD+"' AND D_E_L_E_T_ = ' '"

		If TcSqlExec(cQuery) <> 0
			UserException(OemToAnsi(STR0156) + CRLF + TCSqlError()) //'Erro na atualizańŃo da descrińŃo do produto na amarrańŃo com fornecedor'
		EndIf
	EndIf
EndIf

Return Nil


