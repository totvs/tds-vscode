▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
Function A010EstOri()
	Local aArea := GetArea()
	Local lRet := .T.

	dbSelectArea("SG1")
	dbSetOrder(1)
	If !Empty(M->B1_ESTRORI) .And. !dbSeek(xFilial("SG1")+M->B1_ESTRORI+M->B1_COD) .Or. G1_QUANT > 0
		Help(" ",1,"REGNOIS")
		lRet := .F.
	EndIf

	RestArea(aArea)
Return lRet

