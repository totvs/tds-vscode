*/
Function IntegraSFC()
	Local lRet		:= .F.
	Local xIntSFC	:= SuperGetMV("MV_INTSFC",.F.,0)

	If ValType(xIntSFC) # "N"
		lRet := xIntSFC
	Else
		lRet := xIntSFC == 1
	EndIf

Return(lRet)

