/*/{Protheus.doc} M010GetNCM
	(long_description)
	@type  M010GetNCM
	@author Paulo V. Beraldo
	@since Jan/2020
	@version 1.00
	@return true, logico, retorno da Consulta padrŃo
/*/
Function M010GetNCM()
Local cTec		:= Space( Len( SYD->YD_TEC ) )
Local lConPadOk := ConPad1( NIL , NIL , NIL , 'SYD' , NIL , NIL , .F. )

SYD->( dbSetOrder( 1 ) )

If !( lConPadOk )
	SYD->( dbSeek( FWxFilial( 'SYD' ) + cTec ) )
	If lMvcMata010
		oModel	:= FWModelActive()
		If oModel != Nil .And. oModel:IsActive()
			oSB1Mod	:= oModel:GetModel( 'SB1MASTER' )
			If oModel:GetOperation() == MODEL_OPERATION_INSERT .Or. oModel:GetOperation() == MODEL_OPERATION_UPDATE
				oSB1Mod:LoadValue( 'B1_POSIPI', CriaVar( 'B1_POSIPI', .F. ) )
				oSB1Mod:LoadValue( 'B1_EX_NCM', CriaVar( 'B1_EX_NCM', .F. ) )
				oSB1Mod:LoadValue( 'B1_EX_NBM', CriaVar( 'B1_EX_NBM', .F. ) )
			EndIf
		EndIf
	Else
		If INCLUI .Or. ALTERA
			SetMemVar( 'B1_POSIPI', CriaVar( 'B1_POSIPI', .F. ) )
			SetMemVar( 'B1_EX_NCM', CriaVar( 'B1_EX_NCM', .F. ) )
			SetMemVar( 'B1_EX_NBM', CriaVar( 'B1_EX_NBM', .F. ) )
		EndIf
	EndIf
Else
	If lMvcMata010
		oModel	:= FWModelActive()
		If oModel != Nil .And. oModel:IsActive()
			oSB1Mod	:= oModel:GetModel( 'SB1MASTER' )
			If oModel:GetOperation() == MODEL_OPERATION_INSERT .Or. oModel:GetOperation() == MODEL_OPERATION_UPDATE
				oSB1Mod:LoadValue( 'B1_POSIPI', SYD->YD_TEC 	)
				oSB1Mod:LoadValue( 'B1_EX_NCM', SYD->YD_EX_NCM 	)
				oSB1Mod:LoadValue( 'B1_EX_NBM', SYD->YD_EX_NBM 	)
			EndIf
		EndIf
	Else
		If INCLUI .Or. ALTERA
			SetMemVar( 'B1_POSIPI', SYD->YD_TEC 	)
			SetMemVar( 'B1_EX_NCM', SYD->YD_EX_NCM 	)
			SetMemVar( 'B1_EX_NBM', SYD->YD_EX_NBM 	)
		EndIf
	EndIf

EndIf

Return .T.

/*/{Protheus.doc} A10InitCod()
	Funcao Responsavel por Realizar a Inicializacao Padrao do Codigo do Produto
	@type Function
	@author Paulo V. Beraldo
	@since Jul/2020
	@version 1.00
	@param param, param_type, param_descr
	@return cRet, Caracter	, Retorna o Conteudo para Inicializacao do Campo B1_COD
/*/
Function A10InitCod()
Local cRet		:= CriaVar( 'B1_COD', .F. )
Local aArea 	:= GetArea()
Local aAreaSB1 	:= SB1->( GetArea() )
Local aAreaSX3 	:= SX3->( GetArea() )
Local cSx3Init	:= AllTrim( GetSx3Cache( 'B1_COD', 'X3_RELACAO' ) )

If !( Empty( cSx3Init ) )
	cRet := &( cSx3Init )

	SB1->( dbSetOrder( 1 ) )
	While SB1->( dbSeek( FWxFilial( 'SB1' ) + cRet ) )
		ConfirmSx8()
		cRet :=	GetSx8Num( 'SB1', 'B1_COD' )
	EndDo

EndIf

RestArea( aAreaSX3 )
RestArea( aAreaSB1 )
RestArea( aArea )
Return cRet

/*/{Protheus.doc} INCCPY
FunńŃo utilizada nos inicializadores padr§es (X3_RELACAO) dos campos
B1_OBS, B1_VM_GI, B1_VM_I, B1_VM_P, B1_VM_PROC
@type  Function
@author Squad Entradas
@since 04/02/2026
/*/
Function INCCPY()

Local lRet		:= .T.				as logical
Local oModel	:= FwModelActive()	as object

	if !(valType(oModel) == "U")
		if !(oModel:GetOperation() == MODEL_OPERATION_INSERT)
			lRet := .F.
			if oModel:IsCopy() 	
				lRet := aScan(oModel:GetModel("SB1MASTER"):GetFldNoCopy(),{|x| allTrim(x) == alltrim(Replace(ReadVar(),"M->",""))}) > 0
			endif
		endif
	endif

Return lRet

//------------------------------------------------------------------------------
/*/{Protheus.doc} M010VlCPrd
Verifica se a codificańŃo padronizada por categorias de produtos estß ativada 
e se a rotina de cadastro de categorias versus produto (ACV) estß liberada 
para o cadastro de produtos.

@type       Function
@author     Jorge Martins | Protheus Retail
@since      04/02/2026
@version    12

@return     lRet, Logical, Indica se o cadastro de produtos estß em conformidade 
                           com a configurańŃo de codificańŃo padronizada por categorias de produtos.
/*/
//------------------------------------------------------------------------------
Static Function M010VlCPrd()
Local lRet       as Logical
Local lCfgCodPrd as Logical
Local cRotinas   as Character
Local cProblema  as Character
Local cSolucao   as Character

	lRet       := .T.
	cRotinas   := SuperGetMv("MV_CADPROD",, "|SBZ|SB5|SGI|D3E|") // Rotinas que sŃo utilizadas no cadastro de produto (MATA010)
	lCfgCodPrd := SuperGetMv("MV_PADCOD",, .F.) // ConfigurańŃo de codificańŃo padronizada por categorias de produtos

	// CodificańŃo padronizada estß ativada e o campo de codificańŃo existe, 
	// mas a rotina de categorias de produto nŃo estß na lista de rotinas utilizadas no MATA010
	If lCfgCodPrd  .And. ACU->(ColumnPos("ACU_CDPROD")) > 0
		If !("ACV" $ cRotinas)
			lRet      := .F.
			cProblema := STR0167 // "O uso da codificańŃo padronizada por categorias de produtos estß ativado mas o parŌmetro MV_CADPROD nŃo contķm o cadastro de categorias versus produto (ACV)."
			cSolucao  := STR0168 // "Ajuste a configurańŃo deste parŌmetro para liberar o acesso ao cadastro de produtos."
			Help("", 1, "HELP", ProcName(0), cProblema, 1,,,,,,, {cSolucao})
		EndIf
	EndIf

Return lRet
