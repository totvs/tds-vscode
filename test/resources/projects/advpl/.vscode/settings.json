{
    "totvsLanguageServer.welcomePage": false,
    "totvsLanguageServer.trace.debug": "off",
    "totvsLanguageServer.trace.server": "verbose",
    "totvsLanguageServer.launch.args": [
        "--log-file=totvsls.log",
        "--verbose",
        "--wait-for-attach=30",
        "--debug-ls",
        "--trace-compile",
        "--log-file-append=totvsls2.log"
    ],
    "totvsLanguageServer.askCompileResult": false,
    "totvsLanguageServer.askEncodingChange": false,
    "totvsLanguageServer.editor.autocomplete": "Off",
    "totvsLanguageServer.workspaceServerConfig": false,
    "totvsLanguageServer.editor.codeLens": false,
    "totvsLanguageServer.editor.index.cache": "onDisk",
    "chat.agentFilesLocations": {
        ".github/agents": true,
        ".claude/agents": true,
        "~/.copilot/agents": true,
        ".agents/agents": true
    },
    "totvsLanguageServer.editor.linter.includes": "${workspaceFolder}/includes_prw;${workspaceFolder}/includes_dev;${workspaceFolder}/src/tlpp/rest/includes_dev;${workspaceFolder}/includes;m:\\protheus\\INCLUDES;m:\\protheus\\INCLUDES_TLPP"
}